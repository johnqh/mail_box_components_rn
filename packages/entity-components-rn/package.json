    "src"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "peerDependencies": {
    "@sudobility/components-rn": "^1.0.45",

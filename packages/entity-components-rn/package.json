  },
  "peerDependenciesMeta": {
    "@sudobility/types": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sudobility/components-rn": "^1.0.45",
    "@sudobility/design": "^1.1.28",
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "react": "^18.3.0",
    "react-native": "^0.76.0",
    "react-test-renderer": "18.3.1",
    "@testing-library/react-native": "^13.3.3",
    "@testing-library/jest-native": "^5.4.3",
    "jest": "^29.7.0",
    "babel-jest": "^29.7.0",
    "@babel/preset-env": "^7.27.0",

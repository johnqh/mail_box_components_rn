{
  "name": "@sudobility/entity-components-rn",
  "version": "1.0.3",
  "description": "React Native Entity/Organization components for Sudobility",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
